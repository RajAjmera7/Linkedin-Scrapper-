# Copy this file to .env and fill in your values

# MongoDB Atlas connection string
# Get it from: https://cloud.mongodb.com → your cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/linkedin-post-finder?retryWrites=true&w=majority

# Server port (optional, defaults to 3000)
PORT=3000
